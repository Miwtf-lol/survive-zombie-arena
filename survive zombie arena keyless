                    distLbl.Font = Enum.Font.Gotham
                    distLbl.TextSize = 11
                    distLbl.TextColor3 = Color3.fromRGB(200, 160, 180)
                    distLbl.Parent = billboard

                    billboard.Parent = hrp

                    -- Highlight
                    local highlight = Instance.new("Highlight")
                    highlight.Name = "MiuHub_Highlight"
                    highlight.FillColor = Color3.fromRGB(255, 182, 193)
                    highlight.FillTransparency = 0.5
                    highlight.OutlineColor = Color3.fromRGB(255, 105, 180)
                    highlight.OutlineTransparency = 0.3
                    highlight.Parent = zombie

                    espInstances[zombie] = {
                        billboard = billboard,
                        highlight = highlight,
                        nameLbl = nameLbl,
                        healthLbl = healthLbl,
                        distLbl = distLbl,
                        humanoid = humanoid
                    }
                end

                -- Update ESP info
                local data = espInstances[zombie]
                if data then
                    local hrp = zombie:FindFirstChild("HumanoidRootPart")
                    local hum = zombie:FindFirstChild("Humanoid")
                    if hrp and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                        local dist = (hrp.Position - Player.Character.HumanoidRootPart.Position).Magnitude
                        data.distLbl.Text = "📍 " .. math.floor(dist) .. "m"
                    end
                    if hum then
                        local hp = math.floor(hum.Health)
