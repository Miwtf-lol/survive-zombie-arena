    MaxRemotesPerFire = 6,
    HighlightTarget = true,
    Keybind = Enum.KeyCode.K,
}

local KAState = {
    Connection = nil,
    LastFireTime = 0,
    CurrentTarget = nil,
    TargetHighlight = nil,
    ZombieClient = nil,
    GunClient = nil,
    GunRemotes = nil,
    LastRemoteCount = 0,
    TotalDamageDealt = 0,
}

local KACachedZombies = {}
local KALastScan = 0

-- Find game clients
local function KAFindGameClients()
    if _G.ZombieClient and typeof(_G.ZombieClient) == "table" and _G.ZombieClient.Zombies then
        KAState.ZombieClient = _G.ZombieClient
    end
    if _G.GunClient and typeof(_G.GunClient) == "table" and _G.GunClient.TryFire then
        KAState.GunClient = _G.GunClient
    end
    
    local playerScripts = LocalPlayer:FindFirstChild("PlayerScripts")
    if playerScripts then
        local function scan(parent)
            for _, obj in ipairs(parent:GetChildren()) do
                if obj:IsA("ModuleScript") then
                    local s, r = pcall(function() return require(obj) end)
                    if s and typeof(r) == "table" then
                        if not KAState.ZombieClient and r.Zombies and r.GetNearbyZombieIds then
                            KAState.ZombieClient = r
                        end
                        if not KAState.GunClient and r.TryFire then
                            KAState.GunClient = r
                        end
                    end
                end
                if obj:IsA("Folder") or obj:IsA("ScreenGui") then
                    scan(obj)
                end
            end
        end
        scan(playerScripts)
    end
    
    local gunRemotes = ReplicatedStorage:FindFirstChild("GunRemotes")
    if gunRemotes then
        KAState.GunRemotes = {
            Fire = gunRemotes:FindFirstChild("GunFire"),
            Hit = gunRemotes:FindFirstChild("GunHit"),
        }
    end
end

-- Scan zombies fast
local function KAScanZombiesFast()
    local now = tick()
    if now - KALastScan < 0.1 then
        return KACachedZombies
    end
    KALastScan = now
    
    local zombies = {}
    
    if KAState.ZombieClient and KAState.ZombieClient.Zombies then
        for id, data in pairs(KAState.ZombieClient.Zombies) do
            if data and not data.IsDying and data.Model and data.Model.Parent then
                table.insert(zombies, {
                    Id = id,
                    Data = data,
                    Model = data.Model,
                    Position = data.CurrentPosition or data.TargetPosition,
                    Distance = math.huge,
                })
            end
        end
        KACachedZombies = zombies
        return zombies
    end
    
    local folder = Workspace:FindFirstChild("Zombies_Local")
    if folder then
        for _, model in ipairs(folder:GetChildren()) do
            if model:IsA("Model") then
                local pos = nil
                local hrp = model:FindFirstChild("HumanoidRootPart")
                if hrp then pos = hrp.Position end
                local id = tonumber(model.Name:match("%d+")) or model.Name
                table.insert(zombies, {Id = id, Model = model, Position = pos, Distance = math.huge})
            end
        end
    end
    
    KACachedZombies = zombies
    return zombies
end

-- Get closest zombies
local function KAGetClosestZombies(maxCount)
    local char = LocalPlayer.Character
    if not char then return {} end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return {} end
    
    local myPos = hrp.Position
    local allZombies = KAScanZombiesFast()
    local inRange = {}
    
    for _, zombie in ipairs(allZombies) do
        if zombie.Position then
            local dist = (zombie.Position - myPos).Magnitude
            if dist <= KAConfig.Range then
                zombie.Distance = dist
                table.insert(inRange, zombie)
            end
        end
    end
    
    if #inRange == 0 then return {} end
    if #inRange <= maxCount then return inRange end
    
    -- Sort by distance, take closest
    table.sort(inRange, function(a, b) return a.Distance < b.Distance end)
    local result = {}
    for i = 1, math.min(maxCount, #inRange) do
        table.insert(result, inRange[i])
    end
    return result
end

-- Highlight target
local function KAClearHighlight()
    if KAState.TargetHighlight then
        pcall(function() KAState.TargetHighlight:Destroy() end)
        KAState.TargetHighlight = nil
    end
end

local function KAHighlightTarget(zombie)
    if not KAConfig.HighlightTarget or not zombie or not zombie.Model then
        KAClearHighlight()
        return
    end
    if KAState.CurrentTarget == zombie and KAState.TargetHighlight and KAState.TargetHighlight.Parent then
        return
    end
    KAClearHighlight()
    
    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.fromRGB(220, 40, 40)
    highlight.OutlineColor = Color3.fromRGB(255, 60, 60)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = zombie.Model
    highlight.Parent = zombie.Model
    KAState.TargetHighlight = highlight
end

-- Fire at zombies
local function KAFireAtZombies(zombies)
    if #zombies == 0 then return 0 end
    
    local char = LocalPlayer.Character
    if not char then return 0 end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return 0 end
    
    local origin = hrp.Position + Vector3.new(0, 2, 0)
    local remoteCount = 0
    
    if KAState.GunClient and KAState.GunClient.TryFire then
        local closest = zombies[1]
        if closest and closest.Position then
            local dir = (closest.Position - origin).Unit
            
            local oldGetAim = KAState.GunClient.GetAimDirection
            local wasFiring = KAState.GunClient.IsFiring
            
            if oldGetAim then
                KAState.GunClient.GetAimDirection = function(self) return dir end
            end
            KAState.GunClient.IsFiring = true
            
            pcall(function() KAState.GunClient:TryFire() end)
            remoteCount = remoteCount + 1
            
            if oldGetAim then
                KAState.GunClient.GetAimDirection = oldGetAim
            end
            KAState.GunClient.IsFiring = wasFiring
        end
        
        if KAState.GunRemotes and KAState.GunRemotes.Hit then
            local maxHits = math.min(#zombies, KAConfig.MaxRemotesPerFire)
            for i = 1, maxHits do
                local zombie = zombies[i]
                if zombie and zombie.Id and zombie.Position then
                    pcall(function() KAState.GunRemotes.Hit:FireServer(zombie.Id, zombie.Position) end)
                end
            end
            remoteCount = remoteCount + maxHits
        end
        return remoteCount
    end
    
    if KAState.GunRemotes then
        if KAState.GunRemotes.Fire and zombies[1] and zombies[1].Position then
            pcall(function() KAState.GunRemotes.Fire:FireServer(origin, (zombies[1].Position - origin).Unit) end)
            remoteCount = remoteCount + 1
        end
        
        if KAState.GunRemotes.Hit then
            local maxHits = math.min(#zombies, KAConfig.MaxRemotesPerFire)
            for i = 1, maxHits do
                local zombie = zombies[i]
                if zombie and zombie.Id and zombie.Position then
                    pcall(function() KAState.GunRemotes.Hit:FireServer(zombie.Id, zombie.Position) end)
                end
            end
            remoteCount = remoteCount + maxHits
        end
        return
