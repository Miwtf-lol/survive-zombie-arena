-- Find game clients (remote scanning)
local function KAFindGameClients()
    -- Check global variables first
    if _G.ZombieClient and typeof(_G.ZombieClient) == "table" and _G.ZombieClient.Zombies then
        KAState.ZombieClient = _G.ZombieClient
    end
    if _G.GunClient and typeof(_G.GunClient) == "table" and _G.GunClient.TryFire then
        KAState.GunClient = _G.GunClient
    end
    
    -- Scan PlayerScripts for modules
    local playerScripts = LocalPlayer:FindFirstChild("PlayerScripts")
    if playerScripts then
        local function scanModules(parent)
            for _, obj in ipairs(parent:GetChildren()) do
                if obj:IsA("ModuleScript") then
                    local s, r = pcall(function() return require(obj) end)
                    if s and typeof(r) == "table" then
                        if not KAState.ZombieClient and r.Zombies and r.GetNearbyZombieIds then
                            KAState.ZombieClient = r
                        end
                        if not KAState.GunClient and r.TryFire then
                            KAState.GunClient = r
                        end
                        if not KAState.GunClient and r.Fire and r.IsReloading ~= nil then
                            KAState.GunClient = r
                        end
                    end
                elseif obj:IsA("Folder") or obj:IsA("Configuration") then
                    scanModules(obj)
                end
            end
        end
        scanModules(playerScripts)
    end
    
    -- Find GunRemotes in ReplicatedStorage
    local function scanForGunRemotes(folder, depth)
        if depth > 5 then return end
        for _, obj in ipairs(folder:GetChildren()) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") or obj:IsA("UnreliableRemoteEvent") then
                local name = obj.Name:lower()
                if name:find("gun") or name:find("fire") or name:find("hit") or name:find("shoot") or name:find("bullet") or name:find("weapon") then
                    if not KAState.GunRemotes then KAState.GunRemotes = {} end
                    table.insert(KAState.GunRemotes, obj)
                end
            elseif (obj:IsA("Folder") or obj:IsA("Configuration")) and depth < 5 then
                scanForGunRemotes(obj, depth + 1)
            end
        end
    end
    scanForGunRemotes(ReplicatedStorage, 0)
    
    -- Also check children of common remote containers
    local commonPaths = {
        ReplicatedStorage:FindFirstChild("Remotes"),
        ReplicatedStorage:FindFirstChild("GunRemotes"),
        ReplicatedStorage:FindFirstChild("WeaponRemotes"),
        ReplicatedStorage:FindFirstChild("Weapons"),
        ReplicatedStorage:FindFirstChild("Shared"),
    }
    for _, path in ipairs(commonPaths) do
        if path then
            scanForGunRemotes(path, 0)
        end
    end
    
    return KAState.ZombieClient or KAState.GunClient or (#(KAState.GunRemotes or {}) > 0)
end

-- Get closest zombie target
local function KAGetClosestZombie()
    local closest = nil
    local closestDist = KAConfig.Range
    
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    local hrpPos = hrp.Position
    
    -- Scan via ZombieClient if available
    if KAState.ZombieClient and KAState.ZombieClient.Zombies then
        for _, data in pairs(KAState.ZombieClient.Zombies) do
            local model = data.Model or data
            if typeof(model) == "table" then
                -- Handle table-wrapped zombie data
                local mPos = data.Position or (data.Model and data.Model:IsA("Model") and data.Model:FindFirstChild("HumanoidRootPart"))
                if typeof(mPos) == "Vector3" then
                    local dist = (hrpPos - mPos).Magnitude
                    if dist <= closestDist and data.Health and data.Health > 0 then
                        closestDist = dist
                        closest = {Model = data.Model or nil, Position = mPos, Health = data.Health}
                    end
                end
            elseif model:IsA("Model") then
                local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head")
                local hum = model:FindFirstChildOfClass("Humanoid")
                if root and hum and hum.Health > 0 then
                    local dist = (hrpPos - root.Position).Magnitude
                    if dist <= closestDist then
                        closestDist = dist
                        closest = {Model = model, Position = root.Position, Health = hum.Health, Humanoid = hum, Root = root}
                    end
                end
            end
        end
    end
    
    -- Fallback: manual workspace scan
    if not closest then
        local zombiesFolder = Workspace:FindFirstChild("Zombies_Local") or Workspace:FindFirstChild("Zombies") or Workspace
        local scanRoot = zombiesFolder
        
        if scanRoot == Workspace then
            -- Wide scan
            for _, obj in ipairs(Workspace:GetChildren()) do
                if obj:IsA("Model") and obj ~= LocalPlayer.Character then
                    local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                    local hum = obj:FindFirstChildOfClass("Humanoid")
                    if root and hum and hum.Health > 0 then
                        local dist = (hrpPos - root.Position).Magnitude
                        if dist <= closestDist then
                            closestDist = dist
                            closest = {Model = obj, Position = root.Position, Health = hum.Health, Humanoid = hum, Root = root}
                        end
                    end
                end
            end
        else
            for _, zombie in ipairs(scanRoot:GetChildren()) do
                if zombie:IsA("Model") then
                    local root = zombie:FindFirstChild("HumanoidRootPart") or zombie:FindFirstChild("Head")
                    local hum = zombie:FindFirstChildOfClass("Humanoid")
                    if root and hum and hum.Health > 0 then
                        local dist = (hrpPos - root.Position).Magnitude
                        if dist <= closestDist then
                            closestDist = dist
                            closest = {Model = zombie, Position = root.Position, Health = hum.Health, Humanoid = hum, Root = root}
                        end
                    end
                end
            end
        end
    end
    
    return closest
end

