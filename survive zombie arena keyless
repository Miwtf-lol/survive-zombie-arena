-- Helper functions
function createLabel(parent, text, x, y, color, size)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.5, 0, 0, 22)
    lbl.Position = UDim2.new(x, 0, 0, y)
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextColor3 = color or Color3.fromRGB(255, 255, 255)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = size or 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = parent
    return lbl
end

function createButton(parent, text, x, y, w, h, color, size)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(w, 0, 0, h)
    btn.Position = UDim2.new(x, 0, 0, y)
    btn.BackgroundColor3 = color or Color3.fromRGB(255, 60, 160)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = size or 12
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    btn.Parent = parent
    return btn
end

function createInput(parent, text, x, y, w, h)
    local input = Instance.new("TextBox")
    input.Size = UDim2.new(w, 0, 0, h)
    input.Position = UDim2.new(x, 0, 0, y)
    input.BackgroundColor3 = Color3.fromRGB(200, 50, 140)
    input.Text = text
    input.TextColor3 = Color3.fromRGB(255, 255, 255)
    input.Font = Enum.Font.GothamBold
    input.TextSize = 13
    input.PlaceholderText = "Value"
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 7)
    corner.Parent = input
    input.Parent = parent
    return input
end

