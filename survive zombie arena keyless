    content.BorderSizePixel = 0
    content.ScrollBarThickness = 4
    content.ScrollBarImageColor3 = Color3.fromRGB(255, 105, 180)
    content.ScrollBarImageTransparency = 0.3
    content.CanvasSize = UDim2.new(0, 0, 0, 0)
    content.Visible = false
    content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    content.Parent = Window
    local contentCorner = Instance.new("UICorner")
    contentCorner.CornerRadius = UDim.new(0, 10)
    contentCorner.Parent = content
    
    -- UIListLayout for content
    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 6)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = content
    
    -- Padding
    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, 8)
    padding.PaddingBottom = UDim.new(0, 8)
    padding.PaddingLeft = UDim.new(0, 6)
    padding.PaddingRight = UDim.new(0, 6)
    padding.Parent = content
    
    table.insert(TabButtons, btn)
    table.insert(TabContents, content)
    Tabs[name] = {Button = btn, Content = content, Layout = layout}
    
    btn.MouseButton1Click:Connect(function()
        SwitchTab(name)
    end)
    
    return content, layout
end

local function SwitchTab(name)
    for _, content in pairs(TabContents) do
        content.Visible = false
    end
    for _, btn in pairs(TabButtons) do
        btn.BackgroundTransparency = 0.8
    end
    
    if Tabs[name] then
        Tabs[name].Content.Visible = true
        Tabs[name].Button.BackgroundTransparency = 0.3
        ActiveTab = name
    end
end

