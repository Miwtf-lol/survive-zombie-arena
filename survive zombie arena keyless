local function CreateESP(model)
    if model:FindFirstChild("MiuESP_Highlight") then return true end
    
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    
    local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head") or model:FindFirstChild("Torso")
    if not hrp then return false end
    
    local hl = Instance.new("Highlight")
    hl.Name = "MiuESP_Highlight"
    hl.FillColor = Color3.fromRGB(255,80,160)
    hl.OutlineColor = Color3.fromRGB(255,255,255)
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0.3
    hl.Parent = model
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "MiuESP_Billboard"
    billboard.Parent = model
    billboard.Size = UDim2.new(0, 160, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Adornee = hrp
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Parent = billboard
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = model.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 150, 200)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.TextStrokeTransparency = 0.5
    
    local healthLabel = Instance.new("TextLabel")
    healthLabel.Parent = billboard
    healthLabel.Size = UDim2.new(1, 0, 0.5, 0)
    healthLabel.Position = UDim2.new(0, 0, 0.5, 0)
    healthLabel.BackgroundTransparency = 1
    healthLabel.Text = "❤️ "..math.floor(hum.Health)
    healthLabel.TextColor3 = Color3.fromRGB(255, 80, 120)
    healthLabel.Font = Enum.Font.GothamBold
    healthLabel.TextSize = 14
    healthLabel.TextStrokeTransparency = 0.5
    
    local conn
    conn = hum:GetPropertyChangedSignal("Health"):Connect(function()
        if healthLabel and healthLabel.Parent then
            healthLabel.Text = "❤️ "..math.floor(hum.Health)
        else
            conn:Disconnect()
        end
    end)
    
    return true
end

RunService.RenderStepped:Connect(function()
    if not ESPEnabled then return end
    
    local folder = Workspace:FindFirstChild("Zombies_Local")
    if folder then
        for _, zombie in pairs(folder:GetChildren()) do
            if zombie:IsA("Model") then
                CreateESP(zombie)
            end
        end
    end
    
    for _, obj in pairs(Workspace:GetChildren()) do
        if obj:IsA("Model") and obj ~= LocalPlayer.Character then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                CreateESP(obj)
            end
        end
    end
end)

-- ==================== KILL AURA SECTION ====================

local KASection = CreateSectionBox(MainContent,"Kill Aura")

local AuraEnabled = false
local AuraRange = 50

CreateToggle(KASection,"Enable Kill Aura",false,function(val)
    AuraEnabled = val
end)

local RangeLabel = CreateLabel(KASection,"Aura Range: "..AuraRange)

CreateButton(KASection,"Increase Range +10",function()
    AuraRange = AuraRange + 10
    RangeLabel.Text = "Aura Range: "..AuraRange
end)

CreateButton(KASection,"Decrease Range -10",function()
    AuraRange = math.max(10, AuraRange - 10)
    RangeLabel.Text = "Aura Range: "..AuraRange
end)

RunService.RenderStepped:Connect(function()
    if not AuraEnabled then return end

    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local folder = Workspace:FindFirstChild("Zombies_Local")
    if folder then
        for _, zombie in pairs(folder:GetChildren()) do
            local zhrp = zombie:FindFirstChild("HumanoidRootPart")
            local hum = zombie:FindFirstChildOfClass("Humanoid")
            if zhrp and hum and hum.Health > 0 then
                local dist = (hrp.Position - zhrp.Position).Magnitude
                if dist <= AuraRange then
                    hum.Health = 0
                end
            end
        end
    end
end)

