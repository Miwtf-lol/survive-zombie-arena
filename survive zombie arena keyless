local gunHit, gunFire

local function findRemotes()
    local folder = ReplicatedStorage:FindFirstChild("GunRemotes")
    if folder then
        gunHit = folder:FindFirstChild("GunHit")
        gunFire = folder:FindFirstChild("GunFire")
    end
    if not gunHit then
        for _, v in ipairs(ReplicatedStorage:GetDescendants()) do
            if v:IsA("RemoteEvent") then
                if v.Name:lower():find("hit") or v.Name:lower():find("damage") then
                    gunHit = v
                end
                if v.Name:lower():find("fire") or v.Name:lower():find("shoot") then
                    gunFire = v
                end
            end
        end
    end
    if gunHit and not gunFire then gunFire = gunHit end
    if gunFire and not gunHit then gunHit = gunFire end
    
    print("[MIU VIP] GunHit:", gunHit and gunHit:GetFullName() or "NOT FOUND")
    print("[MIU VIP] GunFire:", gunFire and gunFire:GetFullName() or "NOT FOUND")
end

