    ESPEnabled = val
end)

CreateLabel(ESPSection,"ESP Color: Pink")

local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "ZombieESP"
ESPFolder.Parent = CoreGui

local function CreateESP(model)

    if model:FindFirstChild("MiuESP") then
        return
    end

    local hl = Instance.new("Highlight")
    hl.Name = "MiuESP"
    hl.FillColor = Color3.fromRGB(255,80,160)
    hl.OutlineColor = Color3.fromRGB(255,255,255)
    hl.FillTransparency = 0.5
    hl.Parent = model
end

RunService.RenderStepped:Connect(function()

    if not ESPEnabled then
        return
    end

    local folder = Workspace:FindFirstChild("Zombies_Local")

    if folder then
        for _,zombie in pairs(folder:GetChildren()) do
            if zombie:IsA("Model") then
                CreateESP(zombie)
            end
        end
    end
end)

-- ==================== KILL AURA SECTION ====================

local KASection = CreateSectionBox(MainContent,"Kill Aura")

local AuraEnabled = false
local AuraRange = 50

CreateToggle(KASection,"Enable Kill Aura",false,function(val)
    AuraEnabled = val
end)

CreateLabel(KASection,"Aura Range: 50")

CreateButton(KASection,"Increase Aura Range",function()
    AuraRange = AuraRange + 10
end)

RunService.RenderStepped:Connect(function()

    if not AuraEnabled then
        return
    end

    local char = LocalPlayer.Character
    if not char then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local folder = Workspace:FindFirstChild("Zombies_Local")

    if folder then

        for _,zombie in pairs(folder:GetChildren()) do

            local zhrp = zombie:FindFirstChild("HumanoidRootPart")
            local hum = zombie:FindFirstChildOfClass("Humanoid")

            if zhrp and hum then

                local dist = (hrp.Position - zhrp.Position).Magnitude

                if dist <= AuraRange then
                    hum.Health = 0
                end
            end
        end
    end
end)

