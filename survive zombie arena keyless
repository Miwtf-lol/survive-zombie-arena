-- ---- KILL AURA FIRE LOGIC (OBSIDIAN) ----

local function KAFireAtZombies()
    local currentTime = tick()
    if currentTime - KAState.LastFireTime < KAConfig.FireRate then
        return
    end
    
    local target = KAGetClosestZombie()
    KAState.CurrentTarget = target
    
    if not target then
        KAUpdateTargetHighlight(nil)
        return
    end
    
    KAUpdateTargetHighlight(target.Model)
    
    local targetPos = target.Position
    local targetRoot = target.Root
    local targetModel = target.Model
    local targetHum = target.Humanoid
    
    -- METHOD 1: GunClient.TryFire
    if KAState.GunClient and typeof(KAState.GunClient.TryFire) == "function" then
        local s, e = pcall(function()
            KAState.GunClient.TryFire(targetPos, targetRoot, targetModel, targetHum)
        end)
        if s then KAState.LastFireTime = currentTime end
        return
    end
    
    -- METHOD 2: GunClient:Fire or GunClient.Fire
    if KAState.GunClient and typeof(KAState.GunClient.Fire) == "function" then
        local s, e = pcall(function()
            KAState.GunClient:Fire(targetPos, targetRoot, targetModel, targetHum)
        end)
        if s then KAState.LastFireTime = currentTime end
        return
    end
    
    -- METHOD 3: Fire GunRemotes directly
    if KAState.GunRemotes and #KAState.GunRemotes > 0 then
        local fired = 0
        for i = 1, math.min(KAConfig.MaxRemotesPerFire, #KAState.GunRemotes) do
            local remote = KAState.GunRemotes[i]
            if remote and remote:IsA("RemoteEvent") then
                local s, e = pcall(function()
                    -- Try various argument patterns
                    local args
                    if targetRoot then
                        args = {targetPos, targetRoot, targetModel, targetHum}
                    elseif targetHum then
                        args = {targetHum, targetPos}
                    else
                        args = {targetPos}
                    end
                    remote:FireServer(unpack(args))
                end)
                if s then fired = fired + 1 end
            elseif remote and remote:IsA("RemoteFunction") then
                local s, e = pcall(function()
                    local args
                    if targetRoot then
                        args = {targetPos, targetRoot, targetModel, targetHum}
                    elseif targetHum then
                        args = {targetHum, targetPos}
                    else
                        args = {targetPos}
                    end
                    remote:InvokeServer(unpack(args))
                end)
                if s then fired = fired + 1 end
            end
        end
        if fired > 0 then
            KAState.LastRemoteCount = fired
            KAState.TotalDamageDealt = KAState.TotalDamageDealt + 1
            KAState.LastFireTime = currentTime
        end
    end
    
    -- METHOD 4: Fallback - try scanning for any remote with gun-related names and fire with common args
    local gunRemotes = ReplicatedStorage:FindFirstChild("GunRemotes") or 
                       ReplicatedStorage:FindFirstChild("Remotes") or
                       ReplicatedStorage:FindFirstChild("WeaponRemotes")
    if gunRemotes then
        for _, remote in ipairs(gunRemotes:GetDescendants()) do
            if (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction")) and fired < KAConfig.MaxRemotesPerFire then
                local s, e = pcall(function()
                    if remote:IsA("RemoteEvent") then
                        remote:FireServer(targetPos, targetRoot, targetHum)
                    else
                        remote:InvokeServer(targetPos, targetRoot, targetHum)
                    end
                end)
                if s then fired = fired + 1 end
            end
        end
        if fired > 0 then
            KAState.LastRemoteCount = fired
            KAState.LastFireTime = currentTime
        end
    end
end

-- Main Kill Aura Loop
local function KAStartLoop()
    if KAState.Connection then return end
    
    KAState.Connection = RunService.RenderStepped:Connect(function()
        if not KAConfig.Enabled then return end
        
        -- Periodically re-scan for game clients
        if tick() - KALastScan > 5 then
            KAFindGameClients()
            KALastScan = tick()
            -- Update status labels
            if KAStatusLabels then
                KAStatusLabels.ZCLabel.Text = KAState.ZombieClient and "✓" or "✗"
                KAStatusLabels.GCLabel.Text = KAState.GunClient and "✓" or "✗"
                KAStatusLabels.RCLabel.Text = (KAState.GunRemotes and #KAState.GunRemotes or 0) .. " found"
            end
        end
        
        KAFireAtZombies()
    end)
end

