    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.Parent = parent

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0,8)
    btnCorner.Parent = btn

    btn.MouseButton1Click:Connect(function()
        if callback then callback() end
    end)
    return btn
end

-- ==================== FLY SECTION ====================

local FlySection = CreateSectionBox(MainContent,"Fly Controls")

local Flying = false
local FlySpeed = 50
local BodyGyro = nil
local BodyVelocity = nil

CreateToggle(FlySection,"Enable Fly",false,function(val)
    Flying = val
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    
    if val then
        hum.PlatformStand = true
        
        BodyGyro = Instance.new("BodyGyro")
        BodyGyro.Parent = hrp
        BodyGyro.MaxTorque = Vector3.new(0, 40000, 0)
        BodyGyro.P = 2000
        BodyGyro.D = 500
        BodyGyro.CFrame = CFrame.new(hrp.Position, hrp.Position + (Camera.CFrame.LookVector * Vector3.new(1,0,1)))
        
        BodyVelocity = Instance.new("BodyVelocity")
        BodyVelocity.Parent = hrp
        BodyVelocity.MaxForce = Vector3.new(10000, 10000, 10000)
        BodyVelocity.Velocity = Vector3.new()
    else
        hum.PlatformStand = false
        if BodyGyro then BodyGyro:Destroy() BodyGyro = nil end
        if BodyVelocity then BodyVelocity:Destroy() BodyVelocity = nil end
        hrp.Velocity = Vector3.new()
    end
end)

local SpeedLabel = CreateLabel(FlySection,"Fly Speed: "..FlySpeed)

CreateButton(FlySection,"Increase Speed +10",function()
    FlySpeed = FlySpeed + 10
    SpeedLabel.Text = "Fly Speed: "..FlySpeed
end)

CreateButton(FlySection,"Decrease Speed -10",function()
    FlySpeed = math.max(10, FlySpeed - 10)
    SpeedLabel.Text = "Fly Speed: "..FlySpeed
end)

-- Noclip
local NoclipEnabled = false

CreateToggle(FlySection,"Noclip (Fly thru walls)",false,function(val)
    NoclipEnabled = val
end)

-- Fly update
RunService.RenderStepped:Connect(function()
    if not Flying or not BodyGyro or not BodyVelocity then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    
    -- Keep character upright
    BodyGyro.CFrame = CFrame.new(hrp.Position, hrp.Position + (Camera.CFrame.LookVector * Vector3.new(1,0,1)))
    
    -- Movement
    local move = hum.MoveDirection
    local up = (UserInputService:IsKeyDown(Enum.KeyCode.Space) and 1 or 0)
    local down = (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 1 or 0)
    
    BodyVelocity.Velocity = Vector3.new(
        move.X * FlySpeed,
        (up - down) * FlySpeed,
        move.Z * FlySpeed
    )
end)

-- Noclip
RunService.Stepped:Connect(function()
    if not NoclipEnabled or not Flying then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.CanCollide then
            part.CanCollide = false
        end
    end
end)

