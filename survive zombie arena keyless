    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = zombie.Model
    highlight.Parent = zombie.Model
    KAState.TargetHighlight = highlight
end

local function KAGetEquippedGun()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChildOfClass("Tool")
end

local function KAFireAtZombies(zombies)
    if #zombies == 0 then return 0 end
    
    local gun = KAGetEquippedGun()
    if not gun then return 0 end
    KAState.EquippedGunName = gun.Name
    
    local char = LocalPlayer.Character
    if not char then return 0 end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return 0 end
    
    local origin = hrp.Position + Vector3.new(0, 2, 0)
    local remoteCount = 0
    
    if KAState.GunClient and KAState.GunClient.TryFire then
        local oldGetAim = KAState.GunClient.GetAimDirection
        local wasFiring = KAState.GunClient.IsFiring
        
        local closest = zombies[1]
        if closest and closest.Position then
            local dir = (closest.Position - origin).Unit
            
            if oldGetAim then
                KAState.GunClient.GetAimDirection = function(self) return dir end
            end
            KAState.GunClient.IsFiring = true
            
            pcall(function()
                KAState.GunClient:TryFire()
            end)
            
            remoteCount = remoteCount + 1
        end
        
        if oldGetAim then
            KAState.GunClient.GetAimDirection = oldGetAim
        end
        KAState.GunClient.IsFiring = wasFiring
        
        if KAState.GunRemotes and KAState.GunRemotes.Hit then
            local maxHits = math.min(#zombies, KAConfig.MaxRemotesPerFire)
            
            for i = 1, maxHits do
                local zombie = zombies[i]
                if zombie and zombie.Id and zombie.Position then
                    task.spawn(function()
                        pcall(function()
                            KAState.GunRemotes.Hit:FireServer(gun.Name, zombie.Id, zombie.Position)
                        end)
                    end)
                end
            end
            
            remoteCount = remoteCount + maxHits
        end
        
        return remoteCount
    end
    
    if KAState.GunRemotes then
        if KAState.GunRemotes.Fire and zombies[1] and zombies[1].Position then
            pcall(function()
                KAState.GunRemotes.Fire:FireServer(gun.Name, origin, (zombies[1].Position - origin).Unit)
            end)
            remoteCount = remoteCount + 1
        end
        
        if KAState.GunRemotes.Hit then
            local maxHits = math.min(#zombies, KAConfig.MaxRemotesPerFire)
            
            for i = 1, maxHits do
                local zombie = zombies[i]
                if zombie and zombie.Id and zombie.Position then
                    task.spawn(function()
                        pcall(function()
                            KAState.GunRemotes.Hit:FireServer(gun.Name, zombie.Id, zombie.Position)
                        end)
                    end)
                end
            end
            
            remoteCount = remoteCount + maxHits
        end
        
        return remoteCount
    end
    
    return 0
end

local function KALoop()
    if not KAConfig.Enabled then
        KAClearHighlight()
        KAState.CurrentTarget = nil
        return
    end
    
    local now = tick()
    if now - KAState.LastFireTime < KAConfig.FireRate then return end
    
    local maxTargets = KAConfig.MaxRemotesPerFire
    local targets = KAGetClosestZombies(maxTargets)
    
    if #targets > 0 then
        local remotesFired = KAFireAtZombies(targets)
        KAState.LastRemoteCount = remotesFired
        KAState.TotalDamageDealt = KAState.TotalDamageDealt + #targets
        
        KAState.LastFireTime = now
        KAState.CurrentTarget = targets[1]
        KAHighlightTarget(targets[1])
    else
        KAClearHighlight()
        KAState.CurrentTarget = nil
        KAState.LastRemoteCount = 0
    end
end

