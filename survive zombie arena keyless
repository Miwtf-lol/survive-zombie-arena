--===[ HELPER: Tạo Toggle Row (Pink) ]===--
local function createToggle(parent, label, desc, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -8, 0, 44)
    row.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    row.BackgroundTransparency = 0.92
    row.BorderSizePixel = 0
    row.Parent = parent

    local rowCorner = Instance.new("UICorner")
    rowCorner.CornerRadius = UDim.new(0, 10)
    rowCorner.Parent = row

    local rowStroke = Instance.new("UIStroke")
    rowStroke.Color = Pink.Glass
    rowStroke.Transparency = 0.85
    rowStroke.Thickness = 1
    rowStroke.Parent = row

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -70, 0, 22)
    lbl.Position = UDim2.new(0, 12, 0, 4)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = 14
    lbl.TextColor3 = Pink.White
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = row

    if desc then
        local descLbl = Instance.new("TextLabel")
        descLbl.Size = UDim2.new(1, -70, 0, 16)
        descLbl.Position = UDim2.new(0, 12, 0, 26)
        descLbl.BackgroundTransparency = 1
        descLbl.Text = desc
        descLbl.Font = Enum.Font.Gotham
        descLbl.TextSize = 11
        descLbl.TextColor3 = Color3.fromRGB(200, 170, 180)
        descLbl.TextXAlignment = Enum.TextXAlignment.Left
        descLbl.Parent = row
    end

    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 46, 0, 24)
    toggleBtn.Position = UDim2.new(1, -58, 0.5, -12)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(70, 35, 55)
    toggleBtn.BorderSizePixel = 0
    toggleBtn.Text = ""
    toggleBtn.Parent = row

    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(1, 0)
    toggleCorner.Parent = toggleBtn

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 20, 0, 20)
    knob.Position = UDim2.new(0, 2, 0.5, -10)
    knob.BackgroundColor3 = Color3.fromRGB(200, 180, 190)
    knob.BorderSizePixel = 0
    knob.Parent = toggleBtn

    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = knob

    local isOn = false
    local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    local function updateToggle(state)
        isOn = state
        if isOn then
            local t1 = TweenService:Create(toggleBtn, tweenInfo, {BackgroundColor3 = Pink.Dark})
            local t2 = TweenService:Create(knob, tweenInfo, {Position = UDim2.new(1, -22, 0.5, -10), BackgroundColor3 = Pink.White})
            t1:Play()
            t2:Play()
        else
            local t1 = TweenService:Create(toggleBtn, tweenInfo, {BackgroundColor3 = Color3.fromRGB(70, 35, 55)})
            local t2 = TweenService:Create(knob, tweenInfo, {Position = UDim2.new(0, 2, 0.5, -10), BackgroundColor3 = Color3.fromRGB(200, 180, 190)})
            t1:Play()
            t2:Play()
        end
        if callback then
            pcall(callback, isOn)
        end
    end

    toggleBtn.MouseButton1Click:Connect(function()
        updateToggle(not isOn)
    end)

    return row, function(state)
        updateToggle(state)
    end
end

