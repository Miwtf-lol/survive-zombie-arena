local function getEnemiesInRange(radius)
    local enemies = {}
    local character = player.Character
    if not character then return enemies end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return enemies end
    
    local position = humanoidRootPart.Position
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
            local humanoid = obj:FindFirstChild("Humanoid")
            if not Players:GetPlayerFromCharacter(obj) and humanoid and humanoid.Health > 0 then
                local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso") or obj:FindFirstChild("UpperTorso")
                if root then
                    local dist = (root.Position - position).Magnitude
                    if dist <= radius then
                        table.insert(enemies, {
                            model = obj,
                            root = root,
                            humanoid = humanoid,
                            distance = dist
                        })
                    end
                end
            end
        end
    end
    
    table.sort(enemies, function(a, b)
        return a.distance < b.distance
    end)
    
    return enemies
end

local function fireGunHit(target, hitPosition, hitNormal)
    local success, result = pcall(function()
        local args = { [1] = target, [2] = hitPosition, [3] = hitNormal }
        gunRemotes.GunHit:FireServer(unpack(args))
    end)
    return success
end

local function fireMultiHits(enemyData, hitCount)
    local model = enemyData.model
    local root = enemyData.root
    
    for i = 1, hitCount do
        local hitPos
        if CONFIG.HeadshotMultiplier and model:FindFirstChild("Head") then
            local head = model:FindFirstChild("Head")
            hitPos = head.Position + Vector3.new(
                math.random(-100, 100) / 100,
                math.random(-50, 50) / 100,
                math.random(-100, 100) / 100
            )
        else
            hitPos = root.Position + Vector3.new(
                math.random(-200, 200) / 100,
                math.random(-200, 200) / 100,
                math.random(-200, 200) / 100
            )
        end
        
        local hitNormal = Vector3.new(
            math.random(-100, 100) / 100,
            math.random(-50, 50) / 100,
            math.random(-100, 100) / 100
        ).Unit
        
        fireGunHit(model, hitPos, hitNormal)
        task.wait(0.01)
    end
end

local function fireGunEffect()
    if CONFIG.SilentMode then return end
    local character = player.Character
    if not character then return end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end
    
    pcall(function()
        local args = { [1] = humanoidRootPart.Position, [2] = humanoidRootPart.CFrame.LookVector }
        gunRemotes.GunFire:FireServer(unpack(args))
    end)
end

local function handleAmmo(tool)
    if not tool then return false end
    
    local ammoVars = {"Ammo", "CurrentAmmo", "AmmoCount", "Bullets", "Magazine", "Clip"}
    local ammo = nil
    
    for _, varName in ipairs(ammoVars) do
        ammo = tool:FindFirstChild(varName)
        if ammo then break end
    end
    
    if not ammo then
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, item in ipairs(backpack:GetChildren()) do
                for _, varName in ipairs(ammoVars) do
                    ammo = item:FindFirstChild(varName)
                    if ammo then return true end
                end
            end
        end
        return false
    end
    
    if CONFIG.UseAmmo then
        if ammo.Value <= 0 then
            if CONFIG.InfiniteAmmo then
                local maxAmmo = tool:FindFirstChild("MaxAmmo") or tool:FindFirstChild("MaxBullets")
                if maxAmmo then
                    ammo.Value = maxAmmo.Value
                else
                    ammo.Value = 30
                end
                return true
            end
            return false
        end
        if not CONFIG.InfiniteAmmo then
            ammo.Value = ammo.Value - 1
        end
    end
    return true
end

local function startKillAura()
    if auraEnabled then return end
    auraEnabled = true
    
    print("[MIU HUB] Kill Aura Started - Radius: " .. currentRadius)
    
    killLoop = RunService.Heartbeat:Connect(function()
        if not auraEnabled then return end
        
        local character = player.Character
        if not character then return end
        
        local tool = character:FindFirstChildOfClass("Tool")
        if not tool then return end
        
        if not handleAmmo(tool) then return end
        
        local enemies = getEnemiesInRange(currentRadius)
        
        if #enemies > 0 then
            if CONFIG.VisualEffect and not CONFIG.SilentMode then
                fireGunEffect()
            end
            
            for _, enemyData in ipairs(enemies) do
                fireMultiHits(enemyData, CONFIG.MultiHitPerEnemy)
                totalKills = totalKills + 1
            end
            
            task.wait(CONFIG.FireRate)
        end
    end)
end

local function stopKillAura()
    auraEnabled = false
    if killLoop then
        killLoop:Disconnect()
        killLoop = nil
    end
    print("[MIU HUB] Kill Aura Stopped")
end

-- ==========================================
-- HÀM FLY
-- ==========================================

local function startFly()
    if flyEnabled then return end
    
    local character = player.Character
    if not character then 
        print("[MIU HUB] No character to fly!")
        return 
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not humanoidRootPart then
        print("[MIU HUB] No Humanoid or HumanoidRootPart!")
        return
    end
    
    flyEnabled = true
    humanoid.PlatformStand = true
    
    -- Tạo body mover
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.P = 9e4
    bodyGyro.D = 9e3
    bodyGyro.MaxTorque = Vector3.new(9e5, 9e5, 9e5)
    bodyGyro.CFrame = humanoidRootPart.CFrame
    bodyGyro.Parent = humanoidRootPart
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.MaxForce = Vector3.new(9e5, 9e5, 9e5)
    bodyVelocity.Parent = humanoidRootPart
    
    print("[MIU HUB] Fly Enabled - Speed: " .. CONFIG.FlySpeed)
    
    -- Vòng lặp điều khiển fly
    flyConnection = RunService.RenderStepped:Connect(function()
        if not flyEnabled or not character or not humanoidRootPart then
            stopFly()
            return
        end
        
        local moveDirection = Vector3.new(0, 0, 0)
        local camera = workspace.CurrentCamera
        
        -- WASD di chuyển
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            moveDirection = moveDirection + camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            moveDirection = moveDirection - camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            moveDirection = moveDirection - camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            moveDirection = moveDirection + camera.CFrame.RightVector
        end
        
        -- Space = lên, Shift = xuống
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            moveDirection = moveDirection + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            moveDirection = moveDirection + Vector3.new(0, -1, 0)
        end
        
        if moveDirection.Magnitude > 0 then
            moveDirection = moveDirection.Unit * CONFIG.FlySpeed
        end
        
        bodyVelocity.Velocity = moveDirection
        bodyGyro.CFrame = camera.CFrame
    end)
end

local function stopFly()
    flyEnabled = false
    
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    
    if bodyGyro then
        bodyGyro:Destroy()
        bodyGyro = nil
    end
    
    if bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end
    
    local character = player.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
    
    print("[MIU HUB] Fly Disabled")
end

