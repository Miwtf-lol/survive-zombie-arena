        FlyStatus.Text = "Status: OFF | Speed: " .. CONFIG.FlySpeed
        FlyStatus.TextColor3 = Color3.fromRGB(255, 200, 220)
        StatsLabel.Text = "Kills: " .. totalKills .. " | Fly: OFF"
    end
end)

-- Speed Input
SpeedInput.FocusLost:Connect(function()
    local newSpeed = tonumber(SpeedInput.Text)
    if newSpeed then
        CONFIG.FlySpeed = math.clamp(newSpeed, CONFIG.MinFlySpeed, CONFIG.MaxFlySpeed)
        SpeedInput.Text = tostring(CONFIG.FlySpeed)
        FlyStatus.Text = (flyEnabled and "Status: ON" or "Status: OFF") .. " | Speed: " .. CONFIG.FlySpeed
        print("[MIU HUB] Fly speed updated to: " .. CONFIG.FlySpeed)
    else
        SpeedInput.Text = tostring(CONFIG.FlySpeed)
    end
end)

-- Infinite Ammo Toggle
AmmoBtn.MouseButton1Click:Connect(function()
    CONFIG.InfiniteAmmo = not CONFIG.InfiniteAmmo
    if CONFIG.InfiniteAmmo then
        AmmoBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        AmmoBtn.Text = "∞ Ammo: ON"
    else
        AmmoBtn.BackgroundColor3 = Color3.fromRGB(150, 80, 80)
        AmmoBtn.Text = "∞ Ammo: OFF"
    end
    print("[MIU HUB] Infinite Ammo: " .. tostring(CONFIG.InfiniteAmmo))
end)

-- Auto restart khi respawn
player.CharacterAdded:Connect(function()
    if auraEnabled then
        stopKillAura()
        task.wait(0.5)
        startKillAura()
    end
    if flyEnabled then
        stopFly()
        task.wait(0.5)
        startFly()
    end
end)

-- Update stats
spawn(function()
    while task.wait(1) do
        if ScreenGui and ScreenGui.Parent then
            StatsLabel.Text = "Kills: " .. totalKills .. " | Fly: " .. (flyEnabled and "ON" or "OFF")
        end
    end
end)

