local function findEnemies(range)
    local char = player.Character
    if not char then return {} end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return {} end
    
    local pos = root.Position
    local list = {}
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local hum = obj:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 and not Players:GetPlayerFromCharacter(obj) then
                local r = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso") or obj:FindFirstChild("UpperTorso")
                if r then
                    local d = (r.Position - pos).Magnitude
                    if d <= range then
                        table.insert(list, {model = obj, root = r, hum = hum, dist = d})
                    end
                end
            end
        end
    end
    
    table.sort(list, function(a, b) return a.dist < b.dist end)
    return list
end

local function fireAtEnemy(data)
    if not gunHit then return end
    local parts = {}
    
    if CONFIG.headshot and data.model:FindFirstChild("Head") then
        table.insert(parts, data.model:FindFirstChild("Head"))
    end
    table.insert(parts, data.root)
    
    for _, child in ipairs(data.model:GetChildren()) do
        if child:IsA("BasePart") and #parts < 6 then
            table.insert(parts, child)
        end
    end
    
    for i = 1, CONFIG.multiHit do
        local target = parts[math.random(1, #parts)]
        if target then
            local off = Vector3.new(
                math.random(-200,200)/100, math.random(-200,200)/100, math.random(-200,200)/100
            )
            local norm = Vector3.new(
                math.random(-100,100)/100, math.random(50,100)/100, math.random(-100,100)/100
            ).Unit
            
            pcall(function()
                gunHit:FireServer(data.model, target.Position + off, norm)
            end)
        end
        task.wait(0.005)
    end
end

local function doFX()
    if CONFIG.silent or not gunFire then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    pcall(function() gunFire:FireServer(root.Position, root.CFrame.LookVector) end)
end

local function refillAmmo()
    if not CONFIG.infAmmo then return end
    local char = player.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    for _, child in ipairs(tool:GetDescendants()) do
        if child:IsA("NumberValue") or child:IsA("IntValue") then
            local n = child.Name:lower()
            if n:find("ammo") or n:find("bullet") or n:find("clip") or n:find("mag") then
                local max = tool:FindFirstChild("MaxAmmo") or tool:FindFirstChild("MaxBullets")
                child.Value = max and max.Value or 999
            end
        end
    end
end

local function startAura()
    if auraOn then return end
    auraOn = true
    
    auraConn = RunService.Heartbeat:Connect(function()
        if not auraOn then return end
        local char = player.Character
        if not char then return end
        local tool = char:FindFirstChildOfClass("Tool")
        if not tool then return end
        
        refillAmmo()
        doFX()
        
        local enemies = findEnemies(CONFIG.radius)
        for _, e in ipairs(enemies) do
            fireAtEnemy(e)
            kills = kills + 1
        end
        if #enemies > 0 then task.wait(CONFIG.fireRate) end
    end)
    print("[MIU] Kill Aura STARTED")
end

local function stopAura()
    auraOn = false
    if auraConn then auraConn:Disconnect() auraConn = nil end
    print("[MIU] Kill Aura STOPPED")
end

-- ==========================================
-- FLY
-- ==========================================
local function startFly()
    if flyOn then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    
    flyOn = true
    hum.PlatformStand = true
    hum.AutoRotate = false
    
    bGyro = Instance.new("BodyGyro")
    bGyro.P = 9e4; bGyro.D = 9e3
    bGyro.MaxTorque = Vector3.new(9e5,9e5,9e5)
    bGyro.CFrame = camera.CFrame
    bGyro.Parent = root
    
    bVel = Instance.new("BodyVelocity")
    bVel.Velocity = Vector3.new(0,0,0)
    bVel.MaxForce = Vector3.new(9e5,9e5,9e5)
    bVel.Parent = root
    
    flyConn = RunService.RenderStepped:Connect(function()
        if not flyOn or not char or not root then stopFly() return end
        
        local dir = Vector3.new(0,0,0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + camera.CFrame.LookVector * Vector3.new(1,0,1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - camera.CFrame.LookVector * Vector3.new(1,0,1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - camera.CFrame.RightVector * Vector3.new(1,0,1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + camera.CFrame.RightVector * Vector3.new(1,0,1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir + Vector3.new(0,-1,0) end
        
        if dir.Magnitude > 0 then dir = dir.Unit * CONFIG.flySpeed end
        bVel.Velocity = dir
        bGyro.CFrame = camera.CFrame
    end)
    print("[MIU] Fly STARTED")
end

local function stopFly()
    flyOn = false
    if flyConn then flyConn:Disconnect() flyConn = nil end
    if bGyro then bGyro:Destroy() bGyro = nil end
    if bVel then bVel:Destroy() bVel = nil end
    local char = player.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then hum.PlatformStand = false; hum.AutoRotate = true end
    end
    print("[MIU] Fly STOPPED")
end

