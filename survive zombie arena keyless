local espInstances = {}
local espConnection = nil

function startESP()
    local zombieFolder = workspace:FindFirstChild("Zombies_Local") or workspace:FindFirstChild("Zombies")
    if not zombieFolder then
        warn("[Miu Hub] No Zombies folder found!")
        return
    end

    espConnection = RunService.RenderStepped:Connect(function()
        for _, zombie in ipairs(zombieFolder:GetChildren()) do
            if zombie:IsA("Model") and zombie:FindFirstChild("HumanoidRootPart") then
                if not espInstances[zombie] then
                    local hrp = zombie:FindFirstChild("HumanoidRootPart")
                    local humanoid = zombie:FindFirstChild("Humanoid")

                    -- BillboardGui
                    local billboard = Instance.new("BillboardGui")
                    billboard.Name = "MiuHub_ESP"
                    billboard.Size = UDim2.new(0, 160, 0, 60)
                    billboard.StudsOffset = Vector3.new(0, 3, 0)
                    billboard.AlwaysOnTop = true
                    billboard.Adornee = hrp

                    local bg = Instance.new("Frame")
                    bg.Size = UDim2.new(1, 0, 1, 0)
                    bg.BackgroundColor3 = Pink.Dark
                    bg.BackgroundTransparency = 0.25
                    bg.BorderSizePixel = 0
                    bg.Parent = billboard

                    local bgCorner = Instance.new("UICorner")
                    bgCorner.CornerRadius = UDim.new(0, 8)
                    bgCorner.Parent = bg

                    local nameLbl = Instance.new("TextLabel")
                    nameLbl.Size = UDim2.new(1, -8, 0, 20)
                    nameLbl.Position = UDim2.new(0, 4, 0, 2)
                    nameLbl.BackgroundTransparency = 1
                    nameLbl.Text = "☠ " .. zombie.Name
                    nameLbl.Font = Enum.Font.GothamBold
                    nameLbl.TextSize = 13
                    nameLbl.TextColor3 = Pink.White
                    nameLbl.Parent = billboard

                    local healthLbl = Instance.new("TextLabel")
                    healthLbl.Size = UDim2.new(1, -8, 0, 16)
                    healthLbl.Position = UDim2.new(0, 4, 0, 22)
                    healthLbl.BackgroundTransparency = 1
                    healthLbl.Text = "❤️ Health: ?"
                    healthLbl.Font = Enum.Font.Gotham
                    healthLbl.TextSize = 12
                    healthLbl.TextColor3 = Pink.Light
                    healthLbl.Parent = billboard

                    local distLbl = Instance.new("TextLabel")
                    distLbl.Size = UDim2.new(1, -8, 0, 14)
                    distLbl.Position = UDim2.new(0, 4, 0, 40)
                    distLbl.BackgroundTransparency = 1
                    distLbl.Text = "📍 ?m"
                    distLbl.Font = Enum.Font.Gotham
                    distLbl.TextSize = 11
                    distLbl.TextColor3 = Color3.fromRGB(200, 150, 170)
                    distLbl.Parent = billboard

                    billboard.Parent = hrp

                    -- Highlight
                    local highlight = Instance.new("Highlight")
                    highlight.Name = "MiuHub_Highlight"
                    highlight.FillColor = Pink.Main
                    highlight.FillTransparency = 0.5
                    highlight.OutlineColor = Pink.Dark
                    highlight.OutlineTransparency = 0.3
                    highlight.Parent = zombie

                    espInstances[zombie] = {
                        billboard = billboard,
                        highlight = highlight,
                        nameLbl = nameLbl,
                        healthLbl = healthLbl,
                        distLbl = distLbl,
                        humanoid = humanoid
                    }
                end

                -- Update ESP info
                local data = espInstances[zombie]
                if data then
                    local hrp = zombie:FindFirstChild("HumanoidRootPart")
                    local hum = zombie:FindFirstChild("Humanoid")
                    if hrp and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                        local dist = (hrp.Position - Player.Character.HumanoidRootPart.Position).Magnitude
                        data.distLbl.Text = "📍 " .. math.floor(dist) .. "m"
                    end
                    if hum then
                        local hp = math.floor(hum.Health)
                        local maxHp = math.floor(hum.MaxHealth)
                        data.healthLbl.Text = "❤️ " .. hp .. "/" .. maxHp
                    end
                end
            end
        end

        -- Cleanup
        for zombie, data in pairs(espInstances) do
            if not zombie or not zombie.Parent then
                pcall(function()
                    data.billboard:Destroy()
                    data.highlight:Destroy()
                end)
                espInstances[zombie] = nil
            end
        end
    end)
end

function stopESP()
    if espConnection then
        espConnection:Disconnect()
        espConnection = nil
    end
    for zombie, data in pairs(espInstances) do
        pcall(function()
            data.billboard:Destroy()
            data.highlight:Destroy()
        end)
        espInstances[zombie] = nil
    end
end

--===================================================================
-- KILL AURA FUNCTION
--===================================================================
local killAuraConnection = nil

function startKillAura()
    local zombieFolder = workspace:FindFirstChild("Zombies_Local") or workspace:FindFirstChild("Zombies")
    if not zombieFolder then
        warn("[Miu Hub] No Zombies folder found for Kill Aura!")
        return
    end

    killAuraConnection = RunService.RenderStepped:Connect(function()
        if not toggles.killAura then return end

        local gunClient = _G.GunClient
        local gunRemotes = _G.GunRemotes or game:GetService("ReplicatedStorage"):FindFirstChild("GunRemotes")
        
        for _, zombie in ipairs(zombieFolder:GetChildren()) do
            if zombie:IsA("Model") and zombie:FindFirstChild("HumanoidRootPart") then
                local hrp = zombie:FindFirstChild("HumanoidRootPart")
                local hum = zombie:FindFirstChild("Humanoid")
                if hrp and hum and hum.Health > 0 then
                    local dist = hrp.Position
                    if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                        local myPos = Player.Character.HumanoidRootPart.Position
                        local mag = (dist - myPos).Magnitude
                        if mag <= killRange then
                            -- Try multiple remote methods
                            local success = false
                            
                            -- Method 1: GunClient
                            if gunClient and type(gunClient) == "table" then
                                pcall(function()
                                    if gunClient.Shoot then
                                        gunClient.Shoot(zombie)
                                        success = true
                                    end
                                end)
                                pcall(function()
                                    if gunClient.Hit then
                                        gunClient.Hit(zombie)
                                        success = true
                                    end
                                end)
                            end
                            
                            -- Method 2: GunRemotes
                            if gunRemotes then
                                pcall(function()
                                    local remote = gunRemotes:FindFirstChild("Shoot") or gunRemotes:FindFirstChild("Hit")
                                    if remote then
                                        remote:FireServer(zombie)
                                        success = true
                                    end
                                end)
                            end
                            
                            -- Method 3: Direct damage
                            if not success then
                                pcall(function()
                                    local damageRemote = game:GetService("ReplicatedStorage"):FindFirstChild("DamageEvent") 
                                        or game:GetService("ReplicatedStorage"):FindFirstChild("DealDamage")
                                    if damageRemote then
                                        damageRemote:FireServer(zombie, math.huge)
                                    end
                                end)
                            end
                        end
                    end
                end
            end
        end
    end)
end

function stopKillAura()
    if killAuraConnection then
        killAuraConnection:Disconnect()
        killAuraConnection = nil
    end
end

